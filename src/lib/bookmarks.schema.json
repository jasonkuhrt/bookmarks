{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$defs": {
    "BookmarksConfig": {
      "type": "object",
      "required": ["version", "all"],
      "properties": {
        "version": {
          "type": "number",
          "enum": [2]
        },
        "all": {
          "$ref": "#/$defs/BookmarkTree"
        },
        "safari": {
          "$ref": "#/$defs/SafariBookmarks"
        },
        "chrome": {
          "$ref": "#/$defs/ChromeBookmarks"
        }
      },
      "additionalProperties": false
    },
    "BookmarkTree": {
      "type": "object",
      "required": [],
      "properties": {
        "bar": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        },
        "menu": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        },
        "reading_list": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        },
        "mobile": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        }
      },
      "additionalProperties": false
    },
    "BookmarkNode": {
      "anyOf": [
        {
          "$ref": "#/$defs/BookmarkLeaf"
        },
        {
          "$ref": "#/$defs/BookmarkFolder"
        }
      ]
    },
    "BookmarkLeaf": {
      "type": "object",
      "required": ["name", "url", "_tag"],
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "_tag": {
          "type": "string",
          "enum": ["BookmarkLeaf"]
        }
      },
      "additionalProperties": false
    },
    "BookmarkFolder": {
      "type": "object",
      "required": ["name", "children", "_tag"],
      "properties": {
        "name": {
          "type": "string"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        },
        "_tag": {
          "type": "string",
          "enum": ["BookmarkFolder"]
        }
      },
      "additionalProperties": false
    },
    "SafariBookmarks": {
      "type": "object",
      "required": [],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "bar": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        },
        "menu": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        },
        "reading_list": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        }
      },
      "additionalProperties": false
    },
    "ChromeBookmarks": {
      "type": "object",
      "required": [],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "bar": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        },
        "menu": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        },
        "mobile": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        },
        "profiles": {
          "type": "object",
          "required": [],
          "properties": {},
          "additionalProperties": {
            "$ref": "#/$defs/ChromeProfileBookmarks"
          }
        }
      },
      "additionalProperties": false
    },
    "ChromeProfileBookmarks": {
      "type": "object",
      "required": [],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "bar": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        },
        "menu": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        },
        "mobile": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/BookmarkNode"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$ref": "#/$defs/BookmarksConfig"
}
