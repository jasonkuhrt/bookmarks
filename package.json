{
  "name": "@jasonkuhrt/bookmarks",
  "version": "0.0.0",
  "description": "Cross-browser bookmark sync driven by ~/.bookmarks/bookmarks.yaml",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "bookmarks": "./src/bin/bookmarks.ts"
  },
  "scripts": {
    "lint": "oxlint . --deny-warnings",
    "typecheck": "bunx tsgo --noEmit -p tsconfig.json",
    "test": "bun test",
    "test:integration": "bun test src/bin/bookmarks.test.ts",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir coverage",
    "coverage:check": "bun scripts/check-coverage.ts coverage/lcov.info 85 55",
    "bookmarks": "bun src/bin/bookmarks.ts",
    "generate:json-schema": "bun src/lib/generate-json-schema.ts"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:jasonkuhrt/bookmarks.git"
  },
  "homepage": "https://github.com/jasonkuhrt/bookmarks",
  "bugs": {
    "url": "https://github.com/jasonkuhrt/bookmarks/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@plist/binary.parse": "^1.1.0",
    "@plist/binary.serialize": "^1.1.0",
    "effect": "^3.12.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.2.0",
    "oxlint": "^1.51.0"
  }
}
